{
  "version": 2,
  "builds": [
    { "src": "inventory.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/inventory.html" },
    { "src": "/inventory.css", "dest": "/inventory.css" },
    { "src": "/inventory.js",  "dest": "/inventory.js"  },
    { "src": "/(.*)",          "dest": "/inventory.html"    }
  ]
}
